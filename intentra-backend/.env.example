# Core app settings
APP_NAME=Intentra API
ENVIRONMENT=development
DEBUG=false
CORS_ORIGINS=*
REQUEST_TIMEOUT_SECONDS=45
RECOMMEND_TIMEOUT_SECONDS=60
EXTERNAL_API_TIMEOUT_SECONDS=6
MAX_PLACE_TYPES_PER_QUERY=4
OVERPASS_MAX_MIRRORS_PER_QUERY=2
FALLBACK_PHASE_TIMEOUT_SECONDS=8

# Logging
LOG_LEVEL=INFO

# AI provider
GEMINI_API_KEY=your_gemini_key_here
